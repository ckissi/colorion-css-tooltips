---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CSS Tooltip Library — pure-CSS ::after tooltips, free to copy",
  description = "A library of pure-CSS tooltips in 8 directions with fade and slide reveals — no JavaScript, no dependencies. Click any tooltip to view and copy its CSS.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Self-hosted fonts. Preload the above-the-fold weights (Inter 500 powers
         the hero h1 / LCP element; Inter 400 the body copy) so they arrive
         before paint and the headline doesn't swap late. @font-face lives in
         the inlined global.css. -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/inter-latin-500-normal.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/inter-latin-400-normal.woff2"
      crossorigin
    />
    <!-- Privacy-friendly analytics by Plausible -->
    <script
      async
      src="https://plausible.elerion.com/js/pa-O1sRDOqK8wuW22Au3rYln.js"
    ></script>
    <script is:inline>
      ((window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        }),
        (plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          }));
      plausible.init();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
